<div class="layout">
  <div class="richtext richtext--center gap">
    <span class="title title--base lg:title--large" data-pixel-perfect="true">¿Hay ahora fútbol?</span>
    
    <div class="mt--2 lg:mt--4">
      {% assign blocked = data.is_blocked | default: is_blocked %}
      <span class="title title--xlarge lg:title--xxlarge" style="font-size: 60px; line-height: 1;">{{ blocked }}</span>
    </div>

    <div class="description description--large lg:title--small text--gray text--center">
      {% if blocked == 'SÍ' %}
        ...y por tanto, cientos de webs legítimas están inaccesibles.
      {% else %}
        ...pero, cuando lo hay, cientos de webs están inaccesibles.
      {% endif %}
    </div>
  </div>
</div>

{% assign updated = data.last_update | default: last_update %}
{% render 'title_bar', svg_logo: svg_logo, title: "Estado de LaLiga", update_time: updated %}