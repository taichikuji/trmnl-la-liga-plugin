<div class="layout layout--col layout--center-center gap--medium lg:gap--large">
  <div class="layout__item text--center">
    <img class="image image-dither h--10 lg:h--20" src="data:image/svg+xml;base64,{{ svg_logo | base64_encode }}" />
    <div class="title title--large lg:title--xlarge portrait:title--small mt--2.5">
      ¿Hay ahora fútbol?
    </div>
    <div class="mt--2 lg:mt--4">
      <span class="label label--filled text--xlarge lg:text--xxlarge">{{ data.is_blocked | default: is_blocked }}</span>
    </div>
    <div class="lg:h--5"></div>
    <div class="description lg:description--large text--gray mt--2 lg:mt--4">
      {% if data.is_blocked == 'SÍ' or is_blocked == 'SÍ' %}
        Se han detectado bloqueos activos.
      {% else %}
        No se han detectado bloqueos activos.
      {% endif %}
    </div>
  </div>
</div>

{% render 'title_bar', svg_logo: svg_logo, title: "¿Hay ahora fútbol?", update_time: data.last_update | default: last_update %}