<div class="layout">
  <div class="columns">
    <div class="column">
      <div class="richtext richtext--center gap--medium">
        <span class="title title--large lg:title--xlarge" data-pixel-perfect="true">¿Hay ahora fútbol?</span>
        
        <div class="mt--2 lg:mt--4">
          {% assign blocked = data.is_blocked | default: is_blocked %}
          <span class="title title--xlarge lg:title--xxlarge" style="font-size: 80px; line-height: 1;">{{ blocked }}</span>
        </div>

        <div class="description description--large lg:title--small text--gray text--center">
          {% if blocked == 'SÍ' %}
            ...y por tanto, cientos de webs legítimas están inaccesibles desde los principales ISPs españoles.
          {% else %}
            ...pero, cuando lo hay, cientos de webs legítimas están inaccesibles desde los principales ISPs españoles.
          {% endif %}
        </div>
      </div>
    </div>
  </div>
</div>

{% assign updated = data.last_update | default: last_update %}
{% render 'title_bar', svg_logo: svg_logo, title: "Estado de LaLiga", update_time: updated %}